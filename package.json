{
  "name": "image-resizer-api",
  "version": "1.0.0",
  "description": "Production-grade Image Resizer SaaS backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/image.worker.ts",
    "db:indexes": "ts-node-dev --transpile-only src/db/indexes.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "bullmq": "^5.7.0",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "mongoose": "^8.3.4",
    "pino": "^9.1.0",
    "sharp": "^0.33.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@vitest/coverage-v8": "^4.0.18",
    "pino-pretty": "^11.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
