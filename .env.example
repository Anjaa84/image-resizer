# ──────────────────────────────────────────────────────────────────────────────
# Image Resizer — Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Docker Compose:  MONGO_URI and REDIS_HOST use Docker service names (mongo, redis).
# Local dev:       Change MONGO_URI to mongodb://localhost:27017/image_resizer
#                  and REDIS_HOST to localhost.
# ──────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Docker Compose: mongodb://mongo:27017/image_resizer
# Local dev:      mongodb://localhost:27017/image_resizer
MONGO_URI=mongodb://mongo:27017/image_resizer

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose: redis
# Local dev:      localhost
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── BullMQ ───────────────────────────────────────────────────────────────────
QUEUE_NAME=image-resizer
# Parallel Sharp jobs per worker process. Tune against available CPU cores.
QUEUE_CONCURRENCY=5
# Total attempts per job (1 initial + N-1 retries).
QUEUE_MAX_ATTEMPTS=3
# Initial exponential backoff delay in ms. Attempt 2 → 2s, attempt 3 → 4s.
QUEUE_BACKOFF_DELAY_MS=2000

# ─── Storage ──────────────────────────────────────────────────────────────────
# local = filesystem (development/CI); s3 = AWS S3 (production)
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
# Public base URL used by local storage to construct file URLs.
# Must be reachable by API clients. In Docker Compose with default port mapping
# the host-accessible URL is http://localhost:3000.
APP_BASE_URL=http://localhost:3000
# When true, DELETE /images/:id also removes the file bytes from storage.
# When false (default), the file is kept for a background cleanup sweep.
STORAGE_DELETE_ON_ASSET_DELETE=false

# ─── AWS S3 (required when STORAGE_DRIVER=s3) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ─── Upload & Transform Limits ────────────────────────────────────────────────
# Hard cap on uploaded file size in bytes (default: 50 MB = 52428800).
MAX_UPLOAD_BYTES=52428800
# Maximum transform output dimensions. Requests exceeding these are rejected
# with 422 before any processing occurs.
MAX_IMAGE_WIDTH=10000
MAX_IMAGE_HEIGHT=10000
# Comma-separated MIME types accepted on upload (default: all Sharp-supported).
# Example to restrict to JPEG and PNG only: image/jpeg,image/png
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/avif,image/tiff,image/gif,image/heic,image/heif

# ─── Sync vs Async Transform Decision ────────────────────────────────────────
# A transform runs inline (sync, returns 200) only when ALL thresholds are met.
# Exceeding any threshold offloads to the job queue (async, returns 202).
SYNC_MAX_SOURCE_BYTES=1048576    # 1 MB
SYNC_MAX_OUTPUT_PIXELS=2073600   # 1920 × 1080
SYNC_MAX_COMPLEXITY=1            # max non-resize ops (rotate, grayscale)

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Backed by Redis — consistent across all API replicas.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Graceful Shutdown ────────────────────────────────────────────────────────
# Max ms to wait for in-flight requests/jobs before forcing exit.
SHUTDOWN_TIMEOUT_MS=10000
