# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/image_resizer

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── BullMQ ───────────────────────────────────────────────────────────────────
QUEUE_NAME=image-resize
QUEUE_CONCURRENCY=5

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local          # local | s3
UPLOAD_DIR=./uploads

# ─── AWS S3 (optional) ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Shutdown ─────────────────────────────────────────────────────────────────
# Max milliseconds to wait for in-flight requests before forcing exit
SHUTDOWN_TIMEOUT_MS=10000
